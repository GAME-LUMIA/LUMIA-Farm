# LUMIA Farm 환경변수 예시 — 복사해서 `.env` 로 사용 (실제 .env 는 커밋 금지)

# ── 인증 ──
# 토큰 서명용 시크릿. 배포 시 반드시 무작위 값으로 변경.
FARM_AUTH_SECRET=change-me-to-a-random-secret

# ── 데이터베이스 ──
# 로컬 개발: 아래 두 TURSO_* 를 비워두면 SQLite 파일(api/db/farm.db)을 사용.
# 배포(Vercel 등): Turso(libSQL) 사용 — 아래 값을 채우면 자동으로 원격 DB 사용.
#   설치:  curl -sSfL https://get.tur.so/install.sh | bash
#   생성:  turso db create lumia-farm
#   URL :  turso db show lumia-farm --url        →  libsql://...
#   토큰:  turso db tokens create lumia-farm
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# (선택) 로컬 SQLite 파일 경로 오버라이드
# FARM_DB_PATH=./api/db/farm.db
